# Magento REST base URL (include /rest/V1)
MAGENTO_URL=https://your-store.com/rest/V1

# Integration Access Token from Magento Admin:
# System > Extensions > Integrations > (your integration) > Access Token
ACCESS_TOKEN=your_integration_access_token

# Optional: only required by script.py to generate an admin token
MAGENTO_ADMIN_USERNAME=your_admin_username
MAGENTO_ADMIN_PASSWORD=your_admin_password

# Optional OAuth1 credentials (only needed if you switch to OAuth later)
# CONSUMER_KEY=
# CONSUMER_SECRET=
# ACCESS_TOKEN_SECRET=
